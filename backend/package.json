{
    "name": "nodejs-template-2025",
    "version": "1.0.0",
    "description": "Template project",
    "main": "server.js",
    "scripts": {
        "test": "jest --runInBand",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "start": "node server.js",
        "dev": "nodemon"
    },
    "author": "Kardos Krisztián",
    "license": "ISC",
    "jest": {
        "testEnvironment": "node",
        "testMatch": [
            "**/test/**/*.test.js"
        ],
        "coverageDirectory": "coverage",
        "collectCoverageFrom": [
            "api/**/*.js",
            "sql/**/*.js",
            "!node_modules/**"
        ]
    },
    "devDependencies": {
        "jest": "^30.3.0",
        "nodemon": "^3.1.10",
        "supertest": "^7.2.2"
    },
    "dependencies": {
        "exifreader": "^4.36.0",
        "express": "^5.1.0",
        "express-session": "^1.18.2",
        "leaflet": "^1.9.4",
        "leaflet.markercluster": "^1.5.3",
        "multer": "^2.0.2",
        "mysql2": "^3.15.2",
        "socket.io": "^4.8.3"
    }
}
